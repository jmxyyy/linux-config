custom-shader = ~/.config/ghostty/bloom.glsl
theme = Catppuccin Mocha

# Font Configuration
font-size = 12
font-family = "Maple Mono NF CN"
font-style = "SemiBold Italic"

# Window Configuration
window-inherit-working-directory = true
window-decoration = true
# window-padding-x = 12
# window-padding-y = 12
background-opacity = 0.9
background-blur-radius = 32

# Cursor Configuration
cursor-style = block
cursor-style-blink = false

# Scrollback
scrollback-limit = 3023

# Terminal features
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = true

# Disable annoying copied to clipboard
app-notifications = no-clipboard-copy,no-config-reload

# Key bindings for common actions
#keybind = ctrl+c=copy_to_clipboard
#keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size

keybind = global:cmd+backquote=toggle_quick_terminal
keybind = alt+w=close_surface

# keybind = alt+p>h=new_split:left
# keybind = alt+p>j=new_split:down
# keybind = alt+p>k=new_split:up
# keybind = alt+p>l=new_split:right
#
keybind = alt+m>h=goto_split:left
keybind = alt+m>j=goto_split:down
keybind = alt+m>k=goto_split:up
keybind = alt+m>l=goto_split:right
#
# keybind = alt+r>h=resize_split:left,20
# keybind = alt+r>j=resize_split:down,20
# keybind = alt+r>k=resize_split:up,20
# keybind = alt+r>l=resize_split:right,20
keybind = shift+enter=text:\x1b\r

# Material 3 UI elements
unfocused-split-opacity = 0.7
unfocused-split-fill = #44464f

# Tab configuration
gtk-titlebar = false

# Shell integration
shell-integration = detect
# shell-integration-features = cursor,sudo,title,no-cursor
keybind = shift+enter=text:\n

